# Provider API keys for fetchira's key-based providers. Copy to .env and fill in.
# Web-session providers (gemini_web / perplexity_web / grok_web) need NO key here —
# run `fetchira login <provider>` instead.
SERPER_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
JINA_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=
STEEL_API_KEY=
